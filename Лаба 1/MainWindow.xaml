<Window x:Class="TextEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Лабораторная работа №6 - Внутреннее представление программы" 
        Height="750" Width="950"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Главное меню -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Создать" Click="CreateFile_Click" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Открыть" Click="OpenFile_Click" InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Сохранить" Click="SaveFile_Click" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Сохранить _как" Click="SaveAsFile_Click"/>
                <Separator/>
                <MenuItem Header="В_ыход" Click="Exit_Click" InputGestureText="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="_Правка">
                <MenuItem Header="_Отменить" Click="Undo_Click" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Повторить" Click="Redo_Click" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="Вырезать" Click="Cut_Click" InputGestureText="Ctrl+X"/>
                <MenuItem Header="Копировать" Click="Copy_Click" InputGestureText="Ctrl+C"/>
                <MenuItem Header="Вставить" Click="Paste_Click" InputGestureText="Ctrl+V"/>
                <MenuItem Header="Удалить" Click="Delete_Click"/>
                <Separator/>
                <MenuItem Header="Выделить _все" Click="SelectAll_Click" InputGestureText="Ctrl+A"/>
            </MenuItem>
            <MenuItem Header="_Анализ">
                <MenuItem Header="_Запустить анализ" Click="StartAnalysis_Click" InputGestureText="F5"/>
                <Separator/>
                <MenuItem Header="Постановка задачи" Click="TaskDescription_Click"/>
                <MenuItem Header="Грамматика" Click="Grammar_Click"/>
                <MenuItem Header="Классификация грамматики" Click="GrammarClassification_Click"/>
                <MenuItem Header="Метод анализа" Click="AnalysisMethod_Click"/>
                <MenuItem Header="Тестовые примеры" Click="TestExample_Click"/>
            </MenuItem>
            <MenuItem Header="_Справка">
                <MenuItem Header="Вызов _справки" Click="Help_Click" InputGestureText="F1"/>
                <MenuItem Header="_О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Панель инструментов -->
        <ToolBar DockPanel.Dock="Top" Height="40">
            <Button Click="CreateFile_Click" ToolTip="Создать документ (Ctrl+N)" Style="{StaticResource IconButtonStyle}">
                <Image Width="16" Height="16">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="Black" Geometry="M0,0 L20,0 L20,20 L0,20 Z M3,3 L17,3 L17,17 L3,17 Z M6,6 L14,6 L14,14 L6,14 Z"/>
                                </DrawingGroup>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
            </Button>
            <Button Click="OpenFile_Click" ToolTip="Открыть документ (Ctrl+O)" Style="{StaticResource IconButtonStyle}">
                <Image Width="16" Height="16">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="Black" Geometry="M0,4 L20,4 L20,16 L0,16 Z M2,6 L4,6 L4,14 L2,14 Z M6,6 L18,6 L18,14 L6,14 Z M8,8 L10,8 L10,12 L8,12 Z M12,8 L14,8 L14,12 L12,12 Z"/>
                                </DrawingGroup>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
            </Button>
            <Button Click="SaveFile_Click" ToolTip="Сохранить (Ctrl+S)" Style="{StaticResource IconButtonStyle}">
                <Image Width="16" Height="16">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="Black" Geometry="M2,0 L18,0 L20,2 L20,18 L0,18 L0,2 L2,0 Z M4,2 L4,8 L16,8 L16,2 L4,2 Z M6,10 L14,10 L14,18 L6,18 L6,10 Z"/>
                                </DrawingGroup>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
            </Button>
            <Separator/>
            <Button Click="Undo_Click" ToolTip="Отменить (Ctrl+Z)" Style="{StaticResource IconButtonStyle}">
                <Image Width="16" Height="16">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="Black" Geometry="M10,2 C14,2 18,6 18,10 C18,14 14,18 10,18 C7,18 4,16 2,14 L5,11 C6,12 8,14 10,14 C12,14 14,12 14,10 C14,8 12,6 10,6 C8,6 7,7 6,8 L8,10 L2,10 L2,4 L4,6 C5,4 7,2 10,2 Z"/>
                                </DrawingGroup>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
            </Button>
            <Button Click="Redo_Click" ToolTip="Повторить (Ctrl+Y)" Style="{StaticResource IconButtonStyle}">
                <Image Width="16" Height="16">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="Black" Geometry="M10,2 C13,2 15,4 16,6 L18,4 L18,10 L12,10 L14,8 C13,7 12,6 10,6 C8,6 6,8 6,10 C6,12 8,14 10,14 C12,14 14,12 15,11 L18,14 C16,16 13,18 10,18 C6,18 2,14 2,10 C2,6 6,2 10,2 Z"/>
                                </DrawingGroup>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
            </Button>
            <Separator/>
            <Button Click="Cut_Click" ToolTip="Вырезать (Ctrl+X)" Style="{StaticResource IconButtonStyle}">
                <Image Width="16" Height="16">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="Black" Geometry="M14,2 L18,6 L12,12 L14,14 L16,12 L18,14 L14,18 L12,16 L14,14 L8,8 L2,14 L0,12 L6,6 L2,2 L6,0 L10,4 L14,2 Z M4,4 L6,6 L4,8 L2,6 L4,4 Z"/>
                                </DrawingGroup>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
            </Button>
            <Button Click="Copy_Click" ToolTip="Копировать (Ctrl+C)" Style="{StaticResource IconButtonStyle}">
                <Image Width="16" Height="16">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="Black" Geometry="M4,0 L14,0 L16,2 L16,12 L14,14 L6,14 L4,12 L4,0 Z M6,2 L6,10 L14,10 L14,2 L6,2 Z M0,4 L2,4 L2,16 L12,16 L12,18 L0,18 L0,4 Z"/>
                                </DrawingGroup>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
            </Button>
            <Button Click="Paste_Click" ToolTip="Вставить (Ctrl+V)" Style="{StaticResource IconButtonStyle}">
                <Image Width="16" Height="16">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="Black" Geometry="M6,0 L14,0 L16,2 L16,12 L14,14 L6,14 L4,12 L4,2 L6,0 Z M8,2 L8,10 L12,10 L12,2 L8,2 Z M0,4 L2,4 L2,16 L12,16 L12,18 L0,18 L0,4 Z"/>
                                </DrawingGroup>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
            </Button>
            <Separator/>
            <Button Click="StartAnalysis_Click" ToolTip="Запуск анализа (F5)" Style="{StaticResource IconButtonStyle}">
                <Image Width="16" Height="16">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="Green" Geometry="M4,2 L16,10 L4,18 Z"/>
                                </DrawingGroup>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
            </Button>
            <Separator/>
            <Button Click="Help_Click" ToolTip="Справка (F1)" Style="{StaticResource IconButtonStyle}">
                <Image Width="16" Height="16">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="Blue" Geometry="M8,2 C11,2 14,5 14,8 C14,11 11,13 8,13 L8,15 L6,15 L6,13 C4,13 2,11 2,8 C2,5 5,2 8,2 Z M7,4 C6,4 5,5 5,6 L7,6 C7,5 8,5 8,6 C8,7 7,7 7,8 L7,10 L9,10 L9,7 C10,6 10,5 9,4 C8,4 8,4 7,4 Z M7,11 L9,11 L9,13 L7,13 L7,11 Z"/>
                                </DrawingGroup>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
            </Button>
            <Button Click="About_Click" ToolTip="О программе" Style="{StaticResource IconButtonStyle}">
                <Image Width="16" Height="16">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="Blue" Geometry="M8,2 C11,2 14,5 14,8 C14,11 11,14 8,14 C5,14 2,11 2,8 C2,5 5,2 8,2 Z M7,5 L9,5 L9,7 L7,7 L7,5 Z M7,8 L9,8 L9,11 L7,11 L7,8 Z"/>
                                </DrawingGroup>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
            </Button>
        </ToolBar>

        <!-- Основная область -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="280"/>
            </Grid.RowDefinitions>

            <!-- Заголовок лабораторной работы -->
            <Border Grid.Row="0" Background="#FF2D2D30" Padding="10,5">
                <TextBlock Text="▶ Лабораторная работа №6: Создание внутренней формы представления программы" 
                           Foreground="#FF007ACC" 
                           FontWeight="Bold" 
                           FontSize="14"/>
            </Border>

            <!-- Редактор -->
            <RichTextBox x:Name="EditorBox" 
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Auto"
                        TextChanged="EditorBox_TextChanged"
                        SpellCheck.IsEnabled="False"
                        FontFamily="Consolas"
                        FontSize="14"
                        Margin="5"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        AcceptsTab="True">
                <RichTextBox.Resources>
                    <Style TargetType="{x:Type Paragraph}">
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>

            <!-- Разделитель -->
            <GridSplitter Grid.Row="2" 
                         Height="5" 
                         HorizontalAlignment="Stretch"
                         Background="LightGray"
                         ShowsPreview="True"/>

            <!-- Результаты анализа -->
            <TabControl Grid.Row="3" Margin="5" x:Name="ResultsTabControl">
                <!-- Вкладка лексем -->
                <TabItem Header="📋 Лексемы">
                    <DataGrid x:Name="TokensGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="White"
                              BorderBrush="Gray"
                              BorderThickness="1"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Width="40">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="." RelativeSource="{RelativeSource Self}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Тип лексемы" Binding="{Binding Type}" Width="120"/>
                            <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="*"/>
                            <DataGridTextColumn Header="Строка" Binding="{Binding Line}" Width="60"/>
                            <DataGridTextColumn Header="Позиция" Binding="{Binding Position}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- Вкладка тетрад -->
                <TabItem Header="📐 Тетрады">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" 
                                   Text="Внутреннее представление: тетрады (op, arg1, arg2, result)" 
                                   FontWeight="Bold" 
                                   Margin="5" 
                                   Foreground="#FF007ACC"/>
                        <DataGrid x:Name="TetradsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="White"
                                  BorderBrush="Gray"
                                  BorderThickness="1"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="№" Binding="{Binding Index}" Width="40"/>
                                <DataGridTextColumn Header="Оператор" Binding="{Binding Op}" Width="80"/>
                                <DataGridTextColumn Header="Аргумент 1" Binding="{Binding Arg1}" Width="*"/>
                                <DataGridTextColumn Header="Аргумент 2" Binding="{Binding Arg2}" Width="*"/>
                                <DataGridTextColumn Header="Результат" Binding="{Binding Result}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- Вкладка ПОЛИЗ -->
                <TabItem Header="🔄 ПОЛИЗ">
                    <DockPanel Margin="10">
                        <TextBlock DockPanel.Dock="Top" 
                                   Text="Польская инверсная запись (ПОЛИЗ):" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10" 
                                   Foreground="#FF007ACC"/>
                        <Border BorderBrush="Gray" BorderThickness="1" Background="#FFF5F5F5" Padding="10">
                            <TextBlock x:Name="PolizText" 
                                       FontFamily="Consolas" 
                                       FontSize="16"
                                       TextWrapping="Wrap"
                                       Text=""/>
                        </Border>
                    </DockPanel>
                </TabItem>

                <!-- Вкладка результата вычисления -->
                <TabItem Header="✅ Результат">
                    <DockPanel Margin="10">
                        <TextBlock DockPanel.Dock="Top" 
                                   Text="Результат вычисления выражения:" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10" 
                                   Foreground="#FF007ACC"/>
                        <Border BorderBrush="Gray" BorderThickness="1" Background="#FFF5F5F5" Padding="10">
                            <TextBlock x:Name="ResultText" 
                                       FontFamily="Consolas" 
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="Green"
                                       TextWrapping="Wrap"
                                       Text=""/>
                        </Border>
                    </DockPanel>
                </TabItem>

                <!-- Вкладка ошибок -->
                <TabItem Header="❌ Ошибки">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" 
                                   x:Name="ErrorCountText"
                                   Text="Общее количество ошибок: 0"
                                   FontWeight="Bold"
                                   Margin="5"
                                   Foreground="Red"/>
                        <DataGrid x:Name="ErrorsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="White"
                                  BorderBrush="Gray"
                                  BorderThickness="1"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Тип ошибки" Binding="{Binding ErrorType}" Width="150"/>
                                <DataGridTextColumn Header="Описание" Binding="{Binding Message}" Width="*"/>
                                <DataGridTextColumn Header="Строка" Binding="{Binding Line}" Width="60"/>
                                <DataGridTextColumn Header="Позиция" Binding="{Binding Position}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Строка состояния -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готов к работе"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="CursorPositionText" Text="Стр: 1, Стб: 1"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="FileInfoText" Text="Новый документ"/>
            </StatusBarItem>
        </StatusBar>
    </DockPanel>
</Window>